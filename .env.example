# ─────────────────────────────────────────────────────────────────────────────
# Environment template — dev and production use SEPARATE Supabase projects.
#
# Copy this file to ONE per environment (both are git-ignored):
#   .env.development   → your DEV/staging Supabase project   (used by default)
#   .env.production    → the LIVE Supabase project           (used only with --prod)
#
# How it's loaded (server + scripts, see server/src/env.js):
#   • default            → .env.development
#   • --prod / NODE_ENV=production → .env.production
#   • if neither exists, the legacy single .env is used (transitional)
# The Vite client reads .env.development for `npm run dev` and .env.production
# for a production `vite build` automatically (envDir points at the repo root).
#
# Production hosting (Vercel/Railway) sets its own env vars in the dashboard —
# these files are NOT uploaded there. Keep .env.production locally only to run
# admin/migration scripts against prod deliberately (e.g. `... --prod`).
# Each file must be COMPLETE (no value falls through between environments).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Personal Access Token for HTTPS migrations via the Management API
# (Account → Access Tokens). Used by scripts/run-sql-api.mjs.
SUPABASE_ACCESS_TOKEN=

# Server
PORT=4000
# Where invite / reset links send the user back to (the SPA origin).
# Dev: http://localhost:5173 · Production: the deployed frontend URL.
APP_URL=http://localhost:5173
# Production only: comma-separated frontend origin(s) allowed by CORS.
# Leave unset locally (any origin allowed for the Vite dev server).
# CORS_ORIGIN=https://your-app.vercel.app
# Optional: object-storage bucket name for attachments (default: attachments)
# ATTACHMENTS_BUCKET=attachments

# Client
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Production: the deployed backend URL, e.g. https://your-api.up.railway.app
# Leave empty locally so calls stay relative and use the Vite dev proxy.
VITE_API_BASE_URL=
